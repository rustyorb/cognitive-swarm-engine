# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Search backends for web-grounded research (all optional). Cascade order:
# SearXNG -> Brave -> Serply. The first that returns results wins. Gemini
# specialists use native Google Search grounding regardless of these.

# SEARXNG_URL: A running SearXNG instance (local/self-hosted, no key needed).
# Preferred backend — private and aggregated. The instance MUST have the JSON
# format enabled (settings.yml: search.formats includes "json").
SEARXNG_URL="http://192.168.0.177:8888"

# BRAVE_API_KEY: Brave Search API (used if SearXNG is unset or returns nothing).
BRAVE_API_KEY="MY_BRAVE_API_KEY"

# SERPLY_API_KEY: Serply Search API (last fallback).
SERPLY_API_KEY="MY_SERPLY_API_KEY"
